FROM node:20-alpine
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN corepack enable

WORKDIR /app

# Ensure we have git for pnpm/expo checks
RUN apk add --no-cache git

# Copy root workspace configs
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY core-clients/app-client/package.json ./core-clients/app-client/
COPY core-clients/app-client/apps/mobile/package.json ./core-clients/app-client/apps/mobile/
COPY core-clients/app-client/packages/common/package.json ./core-clients/app-client/packages/common/

RUN pnpm install

EXPOSE 8081 19000 19001 19002

CMD ["pnpm", "start", "--filter", "mobile"]