# ==============================================================================
# CONTAINER & APP CONFIGURATION
# ==============================================================================

# --- DOCKER CONFIGURATION -----------------------------------------------------
COMPOSE_PROJECT_NAME=boilerplate
DOCKER_IMAGE_NAME=ghcr.io/username/repo
DOCKER_IMAGE_TAG=latest

# --- GLOBAL APP CONFIGURATION -------------------------------------------------
SERVICE_SERVER_NAME="Myapp"
SERVICE_SERVER_SLUG="myapp"
SERVICE_SERVER_ENV=local
SERVICE_SERVER_KEY=base64:sd0kx61QbQwyjAKQPetP5eUstHQj8BNYwWtl2XJlwSo=
SERVICE_SERVER_VERSION=v0.0
SERVICE_SERVER_DEBUG=true
SERVICE_NETWORK="myapp"

VITE_SERVICE_SERVER_NAME="${SERVICE_SERVER_NAME}"
VITE_SERVICE_SERVER_ENV="${SERVICE_SERVER_ENV}"
VITE_SERVICE_SERVER_DEBUG="${SERVICE_SERVER_DEBUG}"

# --- DOMAINS & URLS (CLIENT USE THIS URL) -------------------------------------
SERVICE_SCHEME=https
SERVICE_SERVER_DOMAIN=myapp.test
SERVICE_SERVER_URL="${SERVICE_SCHEME}://${SERVICE_SERVER_DOMAIN}"

SERVICE_API_DOMAIN=api.myapp.test
SERVICE_API_URL="${SERVICE_SCHEME}://${SERVICE_API_DOMAIN}"

SERVICE_REVERB_DOMAIN=reverb.myapp.test
SERVICE_REVERB_URL="${SERVICE_SCHEME}://${SERVICE_REVERB_DOMAIN}"

SERVICE_PMA_DOMAIN=phpmyadmin.myapp.test
SERVICE_PMA_ABSOLUTE_URI="${SERVICE_SCHEME}://${SERVICE_PMA_DOMAIN}"

# --- SANCTUM SETUP ------------------------------------------------------------
SESSION_DOMAIN=.${SERVICE_SERVER_DOMAIN}
SESSION_SECURE_COOKIE=true

# --- PORTS (Global mapping) ---------------------------------------------------
SERVICE_LOAD_BALANCER_PORT=5252
SERVICE_LOAD_BALANCER_HMR_PORT=5353

SERVICE_HMR_URL=hmr.myapp.test
VITE_SERVICE_HMR_URL=${SERVICE_HMR_URL}

SERVICE_DEFAULT_TARGET=client-web
SERVICE_SERVER_PORT=3000

# IMPORTANT FOR DEV
SERVICE_SERVER_EXTRA_HOST="host-gateway"
SERVICE_API_EXTRA_HOST="10.240.37.196"

# --- S3 STORAGE ---------------------------------------------------------------
SERVICE_S3_DOMAIN=s3.myapp.test
S3_URL="${SERVICE_SCHEME}://${SERVICE_S3_DOMAIN}"
SERVICE_S3_CONSOLE_DOMAIN=minio.myapp.test
S3_CONSOLE_URL="${SERVICE_SCHEME}://${SERVICE_S3_CONSOLE_DOMAIN}"

# Kalau pakai cdn
# ASSET_URL=cdn.myapp.com

# ==============================================================================
# SECURITY & SSL CONFIGURATION
# ==============================================================================

# --- SSL CONFIG (Development) -------------------------------------------------
# For development using mkcert or Step CA
SSL_CERT_PATH=/etc/nginx/ssl/myapp.pem
SSL_KEY_PATH=/etc/nginx/ssl/myapp.key

# --- STEP CA (Certificate Authority - DEVELOPMENT ONLY) -----------------------
# Note: Production uses Let's Encrypt, not Step CA
STEP_CA_PORT=9696
STEP_CA_NAME="App Boilerplate CA"
STEP_CA_DNS="step-ca,localhost"
STEP_CA_PROVISIONER="admin"
STEP_CA_PASSWORD="changeme"
STEP_CA_ADMIN="admin@myapp.test"
STEP_CA_ADDRESS=":9696"
STEP_CA_URL=https://localhost:9696

# --- PRODUCTION SSL (Let's Encrypt) -------------------------------------------
# Uncomment for production deployment
# USE_LETSENCRYPT=true
# CERTBOT_EMAIL=admin@myapp.com

# ==============================================================================
# BROADCASTING & WEBSOCKETS
# ==============================================================================

# --- REVERB PUBLIC CONFIG -----------------------------------------------------
SERVICE_REVERB_APP_ID=123456              
SERVICE_REVERB_APP_SECRET=esachan231   
SERVICE_REVERB_APP_KEY=pyrghf57am4rz3nxssow
SERVICE_REVERB_HOST="app-socket"
SERVICE_REVERB_PORT=18080
SERVICE_REVERB_SCHEME=http

PUSHER_APP_KEY=12345678
PUSHER_APP_CLUSTER=mt1  

VITE_REVERB_APP_KEY="${SERVICE_REVERB_APP_KEY}"
VITE_REVERB_HOST="${SERVICE_REVERB_HOST}"
VITE_REVERB_PORT="${SERVICE_REVERB_PORT}"
VITE_REVERB_SCHEME="${SERVICE_REVERB_SCHEME}"

VITE_REVERB_URL="${SERVICE_REVERB_URL}"
VITE_REVERB_APP_ID="${SERVICE_REVERB_APP_ID}"
VITE_REVERB_APP_SECRET="${SERVICE_REVERB_APP_SECRET}"   
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# --- 1. LARAVEL -> REVERB (Internal Docker Connection) ------------------------
SERVICE_REVERB_HOST="app-socket"
SERVICE_REVERB_PORT=18080
SERVICE_REVERB_SCHEME="https"

SERVICE_REVERB_SERVER_HOST="0.0.0.0"
SERVICE_REVERB_SERVER_PORT="${SERVICE_REVERB_PORT}"
REVERB_SERVER_PATH=""

# --- 2. BROWSER -> REVERB (Public/Vite Connection) ----------------------------
# Notice we DO NOT use ${SERVICE_REVERB_HOST} here!
VITE_REVERB_HOST="reverb.myapp.test"
VITE_REVERB_PORT=443 # Assuming you are using HTTPS/SSL for the public domain
VITE_REVERB_SCHEME="https"

VITE_REVERB_APP_KEY="${SERVICE_REVERB_APP_KEY}"
VITE_REVERB_APP_ID="${SERVICE_REVERB_APP_ID}"
VITE_REVERB_APP_SECRET="${SERVICE_REVERB_APP_SECRET}"

# (Optional: If your echo.js still uses Pusher keys, make sure they match Reverb!)
VITE_PUSHER_APP_KEY="${SERVICE_REVERB_APP_KEY}"
BROADCAST_CONNECTION=reverb